{
  "name": "blog-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "env": "node src/configs/env.ts",
    "start": "NODE_ENV=prod nest start",
    "start:dev": "NODE_ENV=dev nest start --watch",
    "start:debug": "NODE_ENV=dev nest start --debug --watch",
    "start:prod": "NODE_ENV=prod node dist/main",
    "test:unit": "NODE_ENV=test pnpm typecheck && jest --config test/jest.config.unit.ts",
    "test:unit:cov": "NODE_ENV=test pnpm typecheck && jest --config test/jest.config.unit.ts --coverage",
    "test:int": "NODE_ENV=test pnpm typecheck && jest --config test/jest.config.integration.ts",
    "test:e2e": "NODE_ENV=test pnpm typecheck && jest --config test/jest.config.e2e.ts",
    "typeorm": "NODE_OPTIONS='-r tsconfig-paths/register' typeorm-ts-node-commonjs",
    "migration:create": "NODE_ENV=migration pnpm typeorm migration:create src/common/database/migrations/migration",
    "migration:create:custom": "NODE_ENV=migration pnpm typeorm migration:create",
    "migration:generate": "NODE_ENV=migration pnpm typeorm migration:generate -d src/common/database/migration.main.ts -p src/database/migrations/migration",
    "migration:generate:custom": "NODE_ENV=migration pnpm typeorm migration:generate -d src/common/database/migration.main.ts -p",
    "migration:show": "NODE_ENV=migration pnpm typeorm migration:show -d src/common/database/migration.main.ts",
    "migration:run": "NODE_ENV=migration pnpm typeorm migration:run -d src/common/database/migration.main.ts -t all",
    "migration:run:fake": "NODE_ENV=migration pnpm typeorm migration:run -d src/common/database/migration.main.ts -t all --fake",
    "migration:revert": "NODE_ENV=migration pnpm typeorm migration:revert -d src/common/database/migration.main.ts -t all",
    "migration:revert:fake": "NODE_ENV=migration pnpm typeorm migration:revert -d src/common/database/migration.main.ts -t all --fake",
    "migration:run:prod": "NODE_ENV=migration typeorm migration:run -d dist/common/database/migration.main.js -t all",
    "migration:revert:prod": "NODE_ENV=migration typeorm migration:revert -d dist/common/database/migration.main.js -t all",
    "cli": "ts-node src/cli.ts",
    "seed:load-test": "NODE_ENV=load-test pnpm cli -- seed:load-test"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.3.1",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "nest-commander": "^3.20.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
